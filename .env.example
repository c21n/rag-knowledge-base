# RAG Knowledge Base - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED: API Keys
# =============================================================================
# You must provide at least one of these API keys for LLM and embedding functionality

# OpenAI API Key (optional - for OpenAI models)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Alibaba Bailian API Key (recommended - for Qwen models)
# Get your key from: https://bailian.console.aliyun.com/
API_KEY=your_alibaba_bailian_api_key_here

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite database URL (default: local file)
DATABASE_URL=sqlite:///./data/app.db

# =============================================================================
# ChromaDB Configuration
# =============================================================================

# ChromaDB service host (use 'chromadb' for Docker internal network)
CHROMA_HOST=chromadb

# ChromaDB service port
CHROMA_PORT=8000

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=/chroma/chroma

# =============================================================================
# File Upload Configuration
# =============================================================================

# Directory for uploaded files
UPLOAD_DIR=./uploads

# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# =============================================================================
# Embedding Configuration
# =============================================================================

# Embedding model to use
# Options: text-embedding-v1 (Alibaba), text-embedding-ada-002 (OpenAI)
EMBEDDING_MODEL=text-embedding-v1

# Text chunk size for document processing
CHUNK_SIZE=500

# Overlap between chunks (helps maintain context)
CHUNK_OVERLAP=50

# =============================================================================
# LLM Configuration
# =============================================================================

# LLM model to use
# Options: qwen-max, qwen-plus (Alibaba), gpt-4, gpt-3.5-turbo (OpenAI)
LLM_MODEL=qwen-max

# Temperature for LLM responses (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.7

# =============================================================================
# API Server Configuration
# =============================================================================

# API host binding
API_HOST=0.0.0.0

# API port
API_PORT=8000

# Number of worker processes (set to 1 for development, 4+ for production)
API_WORKERS=4

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins for CORS (comma-separated)
# For development, includes localhost ports
# For production, restrict to your domain
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080,http://localhost:3000

# =============================================================================
# Frontend Configuration
# =============================================================================

# Base URL for API calls from frontend
# In Docker: use http://backend:8000 for internal, http://localhost:8000 for external
VITE_API_BASE_URL=http://localhost:8000

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit your actual .env file to version control
# 2. Keep your API keys secure and rotate them regularly
# 3. For production deployment:
#    - Use strong, unique API keys
#    - Restrict CORS_ORIGINS to your actual domain
#    - Consider using PostgreSQL instead of SQLite
#    - Set up proper logging and monitoring
# =============================================================================
